#
# SAS/C smakefile for ToolManager library (toolmanager.library).
# Run from Source/library: smake
# Builds shared library from C sources and libasm.a (ROMTag, dummy entry).
# Include path: Programmers/include and optionally network include.
# For debug build add DEFINE DEBUG=1 to opts.
#
# Add network include path if building with network support
inc = //SDK/include
opts = NOLINK INCLUDEDIR=$(inc) INCLUDEDIR=/ INCLUDEDIR=/locale 

ldlibs = lib:sc.lib lib:amiga.lib lib:debug.lib 

lib_c_objs = LibInit.o handler.o data.o tmhandle.o objects.o execobj.o imageobj.o\
 soundobj.o menuobj.o iconobj.o dockobj.o accessobj.o rexx.o workbench.o readiff.o\
 hotkey.o locale.o safety.o config.o

lib_objs = libasm.o $(lib_c_objs)
dest = toolmanager.library

all: $(dest)

$(dest): $(lib_objs)
	slink FROM $(lib_objs) TO $(dest) LIB $(ldlibs)

libasm.o: libasm.a
	asm libasm.a

LibInit.o: LibInit.c ToolManagerLib.h
	sc $(opts) LibInit.c
handler.o: handler.c ToolManagerLib.h
	sc $(opts) handler.c
data.o: data.c ToolManagerLib.h
	sc $(opts) data.c
tmhandle.o: tmhandle.c ToolManagerLib.h
	sc $(opts) tmhandle.c
objects.o: objects.c ToolManagerLib.h
	sc $(opts) objects.c
execobj.o: execobj.c ToolManagerLib.h
	sc $(opts) execobj.c
imageobj.o: imageobj.c ToolManagerLib.h
	sc $(opts) imageobj.c
soundobj.o: soundobj.c ToolManagerLib.h
	sc $(opts) soundobj.c
menuobj.o: menuobj.c ToolManagerLib.h
	sc $(opts) menuobj.c
iconobj.o: iconobj.c ToolManagerLib.h
	sc $(opts) iconobj.c
dockobj.o: dockobj.c ToolManagerLib.h
	sc $(opts) dockobj.c
accessobj.o: accessobj.c ToolManagerLib.h
	sc $(opts) accessobj.c
rexx.o: rexx.c ToolManagerLib.h
	sc $(opts) rexx.c
workbench.o: workbench.c ToolManagerLib.h
	sc $(opts) workbench.c
readiff.o: readiff.c ToolManagerLib.h
	sc $(opts) readiff.c
hotkey.o: hotkey.c ToolManagerLib.h
	sc $(opts) hotkey.c
locale.o: locale.c ToolManagerLib.h
	sc $(opts) locale.c
safety.o: safety.c ToolManagerLib.h
	sc $(opts) safety.c
config.o: config.c ToolManagerLib.h
	sc $(opts) config.c

clean:
	-delete \#?.o $(dest) quiet

install:
	-copy $(dest) /SYS/libs/$(dest) clone
